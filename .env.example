# --- Runtime ---
# PORT is set by Railway automatically; in local dev it defaults to 3000.
NODE_ENV=development
SESSION_DAYS=7

# --- Session cookie signing ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# --- Google Sheets (credentials store) ---
# Public CSV URL of the sheet. In Google Sheets:
#   File → Share → Publish to the web → select the "Users" tab,
#   format "Comma-separated values (.csv)" → copy the link.
# WARNING: anyone who knows this URL can read every credential. Keep it secret.
SHEET_CSV_URL=

# --- Last-login logging (Apps Script web app) ---
# Web-app URL of the Apps Script bound to the credentials sheet. See README →
# "Last-login logging" for the script and deployment steps. Empty = disabled.
LAST_LOGIN_WEBHOOK_URL=
# Shared secret. Set the same value in the Apps Script project properties
# under the key LAST_LOGIN_TOKEN.
LAST_LOGIN_TOKEN=
